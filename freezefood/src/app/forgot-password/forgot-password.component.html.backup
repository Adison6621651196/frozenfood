<style>
@import url('https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap');

.forgot-password-page {
  font-family: 'Prompt', sans-serif;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 20px;
}

.forgot-password-container {
  background: white;
  border-radius: 0;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  max-width: 500px;
  width: 100%;
  padding: 40px;
  border: 1px solid #e5e7eb;
}

.forgot-password-header {
  text-align: center;
  margin-bottom: 30px;
}

.forgot-password-header h2 {
  color: #333;
  font-size: 1.8rem;
  font-weight: 600;
  margin-bottom: 10px;
}

.forgot-password-header p {
  color: #666;
  font-size: 0.95rem;
  margin: 0;
}

.step-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10px;
  margin-bottom: 30px;
}

.step {
  display: flex;
  align-items: center;
  gap: 8px;
}

.step-circle {
  width: 35px;
  height: 35px;
  border-radius: 0;
  background: #e0e0e0;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.9rem;
}

.step.active .step-circle {
  background: #1e5ba8;
  color: white;
}

.step-text {
  color: #999;
  font-size: 0.9rem;
  font-weight: 500;
}

.step.active .step-text {
  color: #1e5ba8;
}

.step-divider {
  width: 40px;
  height: 2px;
  background: #e0e0e0;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  color: #333;
  font-weight: 500;
  margin-bottom: 8px;
  font-size: 0.95rem;
}

.form-group input {
  width: 100%;
  padding: 12px 15px;
  border: 2px solid #e1e5e9;
  border-radius: 0;
  font-size: 1rem;
  font-family: 'Prompt', sans-serif;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.form-group input:focus {
  outline: none;
  border-color: #1e5ba8;
  box-shadow: 0 0 0 3px rgba(30, 91, 168, 0.1);
}

.password-input-wrapper {
  position: relative;
}

.password-input-wrapper input {
  padding-right: 45px;
}

.password-toggle {
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #999;
  cursor: pointer;
  padding: 5px;
  transition: color 0.3s ease;
}

.password-toggle:hover {
  color: #1e5ba8;
}

.btn-primary {
  width: 100%;
  padding: 14px;
  background: #000000;
  color: white;
  border: none;
  border-radius: 0;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: 'Prompt', sans-serif;
  margin-top: 10px;
}

.btn-primary:hover:not(:disabled) {
  background: #333333;
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
}

.btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.btn-secondary {
  width: 100%;
  padding: 12px;
  background: transparent;
  color: #1e5ba8;
  border: 2px solid #1e5ba8;
  border-radius: 0;
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: 'Prompt', sans-serif;
  margin-top: 10px;
}

.btn-secondary:hover {
  background: #1e5ba8;
  color: white;
}

/* Tabs */
.tabs {
  display: flex;
  gap: 0;
  margin-bottom: 25px;
  border: 2px solid #e1e5e9;
  border-radius: 0;
  overflow: hidden;
}

.tab-btn {
  flex: 1;
  padding: 14px;
  background: white;
  color: #666;
  border: none;
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: 'Prompt', sans-serif;
  border-right: 1px solid #e1e5e9;
}

.tab-btn:last-child {
  border-right: none;
}

.tab-btn.active {
  background: #1e5ba8;
  color: white;
  font-weight: 600;
}

.tab-btn:hover:not(.active) {
  background: #f0f4ff;
}

.tab-label {
  color: #333;
  font-weight: 500;
  margin-bottom: 12px;
  font-size: 0.95rem;
}

.form-input-large {
  width: 100%;
  padding: 14px 15px;
  border: 2px solid #e1e5e9;
  border-radius: 0;
  font-size: 1rem;
  font-family: 'Prompt', sans-serif;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.form-input-large:focus {
  outline: none;
  border-color: #1e5ba8;
  box-shadow: 0 0 0 3px rgba(30, 91, 168, 0.1);
}

.btn-submit {
  margin-top: 10px;
}

.info-box-bottom {
  background: #f0f4ff;
  border-radius: 0;
  padding: 15px;
  margin-top: 20px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  border: 1px solid #e1e5e9;
}

.info-content {
  flex: 1;
}

.info-title {
  color: #333;
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: 5px;
  line-height: 1.4;
}

.info-subtitle {
  color: #666;
  font-size: 0.85rem;
  line-height: 1.4;
}

.btn-back {
  width: 100%;
  padding: 12px;
  background: white;
  color: #1e5ba8;
  border: 2px solid #1e5ba8;
  border-radius: 0;
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: 'Prompt', sans-serif;
  margin-top: 15px;
}

.btn-back:hover {
  background: #f0f4ff;
}

.info-box {
  background: #f0f4ff;
  border-left: 4px solid #1e5ba8;
  padding: 15px;
  border-radius: 0;
  margin-bottom: 20px;
}

.info-box p {
  margin: 0;
  color: #555;
  font-size: 0.9rem;
  line-height: 1.6;
}


@media (max-width: 576px) {
  .forgot-password-container {
    padding: 30px 20px;
  }

  .forgot-password-header h2 {
    font-size: 1.5rem;
  }

  .step-text {
    display: none;
  }

  .step-divider {
    width: 30px;
  }
}
</style>

<div class="forgot-password-page">
  <div class="forgot-password-container">
    <!-- Header -->
    <div class="forgot-password-header">
      <h2>ลืมรหัสผ่าน</h2>
      <p *ngIf="step === 'verify'">กรอกอีเมลหรือเบอร์โทรศัพท์ที่ใช้ตอนสมัครเพื่อรีเซ็ตรหัสผ่าน</p>
      <p *ngIf="step === 'reset'">ตั้งรหัสผ่านใหม่</p>
    </div>

    <!-- Step Indicator -->
    <div class="step-indicator">
      <div class="step" [class.active]="step === 'verify'">
        <div class="step-circle">1</div>
        <span class="step-text">ยืนยันตัวตน</span>
      </div>
      <div class="step-divider"></div>
      <div class="step" [class.active]="step === 'reset'">
        <div class="step-circle">2</div>
        <span class="step-text">รีเซ็ตรหัสผ่าน</span>
      </div>
    </div>

    <!-- ขั้นตอน 1: ยืนยันตัวตน -->
    <div *ngIf="step === 'verify'">
      <!-- Tabs -->
      <div class="tabs">
        <button 
          class="tab-btn" 
          [class.active]="selectedTab === 'email'"
          (click)="switchTab('email')">
          รีเซ็ตด้วยอีเมล
        </button>
        <button 
          class="tab-btn" 
          [class.active]="selectedTab === 'phone'"
          (click)="switchTab('phone')">
          รีเซ็ตด้วยเบอร์โทร
        </button>
      </div>

      <!-- Tab Content: อีเมล -->
      <div *ngIf="selectedTab === 'email'">
        <div class="tab-label">อีเมล</div>
        <form (ngSubmit)="onVerify()">
          <div class="form-group">
            <input
              type="text"
              id="email"
              [(ngModel)]="verifyEmailData.email"
              name="email"
              placeholder="กรอกอีเมลของคุณ"
              class="form-input-large"
              required>
          </div>

          <button type="submit" class="btn-primary btn-submit" [disabled]="isLoading">
            {{ isLoading ? 'กำลังดำเนินการ...' : 'ดำเนินการต่อ' }}
          </button>
        </form>
      </div>

      <!-- Tab Content: เบอร์โทร -->
      <div *ngIf="selectedTab === 'phone'">
        <div class="tab-label">อีเมล</div>
        <form (ngSubmit)="onVerify()">
          <div class="form-group">
            <input
              type="text"
              id="username-phone"
              [(ngModel)]="verifyPhoneData.username"
              name="username"
              placeholder="กรอกอีเมลของคุณ"
              class="form-input-large"
              required>
          </div>

          <div class="tab-label" style="margin-top: 15px;">เบอร์โทรศัพท์</div>
          <div class="form-group">
            <input
              type="tel"
              id="phone"
              [(ngModel)]="verifyPhoneData.phone"
              name="phone"
              placeholder="กรอกเบอร์โทรศัพท์ 10 หลัก"
              class="form-input-large"
              maxlength="10"
              (keypress)="onlyNumbers($event)"
              required>
          </div>

          <button type="submit" class="btn-primary btn-submit" [disabled]="isLoading">
            {{ isLoading ? 'กำลังดำเนินการ...' : 'ดำเนินการต่อ' }}
          </button>
        </form>
      </div>

      <!-- Info Box -->
      <div class="info-box-bottom">
        <div class="info-content">
          <div class="info-title">รีเซ็ตด้วยอีเมล: ระบบจะตรวจสอบอีเมลที่คุณใช้สมัครคุณ</div>
          <div class="info-subtitle">💡 เคล็ดลับ: หากคุณลืมอีเมลหรือตัวรหัสผ่านทีแถน ให้ใช้เบอร์โทรศัพท์แทน</div>
        </div>
      </div>

      <!-- กลับไปหน้าเข้าสู่ระบบ -->
      <button type="button" class="btn-back" (click)="backToLogin()">
        ← กลับไปหน้าเข้าสู่ระบบ
      </button>
    </div>

    <!-- ขั้นตอน 2: ตั้งรหัสผ่านใหม่ -->
    <div *ngIf="step === 'reset'">
      <div class="info-box">
        <p>ยืนยันตัวตนสำเร็จ! กรุณาตั้งรหัสผ่านใหม่</p>
      </div>

      <form (ngSubmit)="onResetPassword()">
        <div class="form-group">
          <label for="newPassword">รหัสผ่านใหม่ *</label>
          <div class="password-input-wrapper">
            <input
              [type]="showPassword ? 'text' : 'password'"
              id="newPassword"
              [(ngModel)]="resetData.newPassword"
              name="newPassword"
              placeholder="กรอกรหัสผ่านใหม่ (อย่างน้อย 6 ตัวอักษร)"
              minlength="6"
              required>
            <button
              type="button"
              class="password-toggle"
              (click)="togglePasswordVisibility()">
              <i [class]="showPassword ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="confirmPassword">ยืนยันรหัสผ่านใหม่ *</label>
          <div class="password-input-wrapper">
            <input
              [type]="showConfirmPassword ? 'text' : 'password'"
              id="confirmPassword"
              [(ngModel)]="resetData.confirmPassword"
              name="confirmPassword"
              placeholder="กรอกรหัสผ่านใหม่อีกครั้ง"
              minlength="6"
              required>
            <button
              type="button"
              class="password-toggle"
              (click)="toggleConfirmPasswordVisibility()">
              <i [class]="showConfirmPassword ? 'fas fa-eye-slash' : 'fas fa-eye'"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn-primary" [disabled]="isLoading">
          {{ isLoading ? '⏳ กำลังบันทึก...' : 'เปลี่ยนรหัสผ่าน' }}
        </button>
      </form>
    </div>
  </div>
</div>
